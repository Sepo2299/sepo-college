{
  "name": "sepocollege-website",
  "version": "1.0.0",
  "description": "Sepo College Website - Full Stack Application",
  "main": "index.js",
  "scripts": {
    "start:backend": "cd backend && npm start",
    "start:frontend": "cd frontend && npm start",
    "install:all": "cd backend && npm install && cd ../frontend && npm install",
    "dev": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "build": "cd frontend && npm run build",
    "postinstall": "npm run install:all"
  },
  "keywords": [
    "college",
    "education",
    "namibia",
    "e-learning"
  ],
  "author": "Sepo College",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "axios": "^1.13.4",
    "bcryptjs": "^3.0.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}